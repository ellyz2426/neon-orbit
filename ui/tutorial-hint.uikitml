<container flexDirection="column" backgroundColor="#000022" backgroundOpacity="0.85" borderRadius="12" padding="8" gap="4" alignItems="center" width="400" height="80">
  <text name="hint-icon" fontSize="14" color="#ffaa00" fontWeight="bold">TIP</text>
  <text name="hint-text" fontSize="10" color="#aabbdd" textAlign="center">Hold trigger to charge, release to launch</text>
  <text name="hint-dismiss" fontSize="8" color="#667799" cursor="pointer">[tap to dismiss]</text>
</container>
